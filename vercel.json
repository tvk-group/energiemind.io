{
  "framework": "nextjs",
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "energiemind.io" }],
      "destination": "/en/",
      "permanent": true
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "www.energiemind.io" }],
      "destination": "/en/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
