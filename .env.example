# @supabase/server SDK (server-side — never commit secret key)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json

# Browser / Next.js public aliases (optional if SUPABASE_* are set)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Legacy fallback
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# App URL for auth redirects
NEXT_PUBLIC_APP_URL=https://energiemind.io

# Direct Postgres connection (migrations, CLI, SQL tools — never commit password)
# Get password from Supabase Dashboard → Project Settings → Database
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project.supabase.co:5432/postgres
